<?xml version="1.0" encoding="utf-8"?>
<!--
  Backup & device-transfer rules for Android 12 (API 31) and above.
  Only the DataStore-backed app settings are included.
-->
<data-extraction-rules>
    <cloud-backup>
        <include domain="file" path="datastore/" />
    </cloud-backup>
    <device-transfer>
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
