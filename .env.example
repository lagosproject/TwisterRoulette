# ==============================================================================
# Twister Roulette - Environment Template (.env.example)
#
# Copy this file to '.env' and fill in your local values.
# NEVER commit the actual '.env' file or keystore passwords to git!
# ==============================================================================

# ==========================================
# Android Signing Configuration
# ==========================================
# Absolute path to the directory containing upload-keystore.jks and upload-credentials.txt.
# In build.gradle.kts, this overrides the default SynologyDrive fallback path.
TWISTER_KEYSTORE_DIR=/path/to/your/secure/keystore/directory

# Keystore Credentials (if used in automated release scripts/fastlane)
RELEASE_KEYSTORE_PASSWORD=<YOUR_RELEASE_KEYSTORE_PASSWORD_HERE>
RELEASE_KEY_ALIAS=<YOUR_RELEASE_KEY_ALIAS_HERE>
RELEASE_KEY_PASSWORD=<YOUR_RELEASE_KEY_PASSWORD_HERE>

# ==========================================
# Google Play Console / CI/CD Deployment
# ==========================================
# Path to your Google Play Service Account JSON key for Fastlane or Gradle Play Publisher (GPP)
GOOGLE_PLAY_JSON_KEY_PATH=/path/to/your/play-service-account-key.json

# ==========================================
# Developer Configuration (Optional)
# ==========================================
# Set to 'true' to enable verbose logging or debugging modes in specific environments
DEBUG_LOGGING=false
